# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FIREBASE_SERVICE_ACCOUNT_JSON: Optional JSON credentials string for Firebase Admin SDK on the server.
# Needed for secure token verification and server-authoritative friend request APIs.
# Example: {"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Recommended safer alternative: path to a local service account JSON file.
# Example: ./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_FILE=""

# Firebase Web SDK config for the frontend app.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_DATABASE_ID=""
